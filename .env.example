# App
APP_NAME=Gifte
APP_URL=http://localhost:3000
NODE_ENV=development

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api
API_PORT=4000

# PostgreSQL / Prisma
POSTGRES_USER=gifte
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_DB=gifte
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gifte:replace-with-local-password@postgres:5432/gifte

# Auth
AUTH_SECRET=replace-with-local-development-secret
AUTH_PROVIDER_CLIENT_ID=replace-with-client-id
AUTH_PROVIDER_CLIENT_SECRET=replace-with-client-secret

# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_NAME=gifte-jobs

# AI
AI_PROVIDER=openai
AI_API_KEY=replace-with-ai-api-key
AI_MODEL=replace-with-model-name

# Payments
STRIPE_PUBLIC_KEY=pk_test_replace_with_public_key
STRIPE_SECRET_KEY=sk_test_replace_with_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_webhook_secret

# Email
EMAIL_PROVIDER_API_KEY=replace-with-email-api-key
EMAIL_FROM=no-reply@example.com

# Media Storage
MEDIA_STORAGE_URL=https://example.com/storage
MEDIA_STORAGE_ACCESS_KEY=replace-with-access-key
MEDIA_STORAGE_SECRET_KEY=replace-with-secret-key

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# App
APP_NAME=Gifte
APP_URL=http://localhost:3000
NODE_ENV=development

# API
API_BASE_URL=http://localhost:3000/api

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth
AUTH_SECRET=replace-with-local-development-secret
AUTH_PROVIDER_CLIENT_ID=replace-with-client-id
AUTH_PROVIDER_CLIENT_SECRET=replace-with-client-secret

# Payments
STRIPE_PUBLIC_KEY=pk_test_replace_with_public_key
STRIPE_SECRET_KEY=sk_test_replace_with_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_webhook_secret

# Email
EMAIL_PROVIDER_API_KEY=replace-with-email-api-key
EMAIL_FROM=no-reply@example.com

# Media Storage
MEDIA_STORAGE_URL=https://example.com/storage
MEDIA_STORAGE_ACCESS_KEY=replace-with-access-key
MEDIA_STORAGE_SECRET_KEY=replace-with-secret-key
